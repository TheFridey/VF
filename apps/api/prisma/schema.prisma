generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============ ENUMS ============

enum UserRole {
  VETERAN_UNVERIFIED
  VETERAN_VERIFIED
  VETERAN_MEMBER
  MODERATOR
  ADMIN
}

enum UserStatus {
  PENDING
  ACTIVE
  SUSPENDED
  BANNED
  PENDING_DELETION
  DELETED
}

enum Gender {
  MALE
  FEMALE
  NON_BINARY
  OTHER
  PREFER_NOT_TO_SAY
}

enum MilitaryBranch {
  BRITISH_ARMY
  ROYAL_NAVY
  ROYAL_AIR_FORCE
  ROYAL_MARINES
  RESERVE_FORCES
  TERRITORIAL_ARMY
  ARMY
  NAVY
  AIR_FORCE
  MARINE_CORPS
  COAST_GUARD
  SPACE_FORCE
  NATIONAL_GUARD
  OTHER
}

enum VerificationStatus {
  PENDING
  APPROVED
  REJECTED
  EXPIRED
}

enum ConnectionType {
  BROTHERS_IN_ARMS
  COMMUNITY
}

enum ConnectionStatus {
  PENDING
  ACTIVE
  CANCELLED
  EXPIRED
}

enum ReportReason {
  FAKE_PROFILE
  HARASSMENT
  INAPPROPRIATE_CONTENT
  SPAM
  SCAM
  IMPERSONATION
  UNDERAGE
  OTHER
}

enum ReportStatus {
  PENDING
  DISMISSED
  RESOLVED
  ESCALATED
  ACTION_TAKEN
}

enum MembershipTier {
  FREE
  BIA_BASIC
  BIA_PLUS
}

enum MembershipStatus {
  ACTIVE
  CANCELLED
  PAST_DUE
  EXPIRED
}

enum MembershipGrantSource {
  REFERRAL
  ADMIN
}

// ============ MODELS ============

model User {
  id                       String     @id @default(uuid())
  email                    String     @unique
  passwordHash             String     @map("password_hash")
  role                     UserRole   @default(VETERAN_UNVERIFIED)
  status                   UserStatus @default(PENDING)
  emailVerified            Boolean    @default(false) @map("email_verified")
  emailVerificationToken   String?    @map("email_verification_token")
  emailVerificationExpires DateTime?  @map("email_verification_expires")
  passwordResetToken       String?    @map("password_reset_token")
  passwordResetExpires     DateTime?  @map("password_reset_expires")
  refreshTokenHash         String?    @map("refresh_token_hash")
  refreshTokenExpiresAt    DateTime?  @map("refresh_token_expires_at")
  lastLoginAt              DateTime?  @map("last_login_at")
  failedLoginAttempts      Int        @default(0) @map("failed_login_attempts")
  lastFailedLoginAt        DateTime?  @map("last_failed_login_at")
  lockedUntil              DateTime?  @map("locked_until")
  lastActiveAt             DateTime   @default(now()) @map("last_active_at")
  isOnline                 Boolean    @default(false) @map("is_online")
  banReason                String?    @map("ban_reason")
  banExpiresAt             DateTime?  @map("ban_expires_at")
  referralCode             String?    @unique @map("referral_code")
  deletionRequestedAt      DateTime?  @map("deletion_requested_at")
  scheduledDeletionAt      DateTime?  @map("scheduled_deletion_at")
  createdAt                DateTime   @default(now()) @map("created_at")
  updatedAt                DateTime   @updatedAt @map("updated_at")
  deletedAt                DateTime?  @map("deleted_at")

  profile              Profile?
  veteranDetails       VeteranDetails?
  verificationRequests VerificationRequest[]
  connectionsAsUser1   Connection[]          @relation("ConnectionUser1")
  connectionsAsUser2   Connection[]          @relation("ConnectionUser2")
  sentMessages         Message[]             @relation("MessageSender")
  receivedMessages     Message[]             @relation("MessageReceiver")
  blocks               Block[]               @relation("Blocker")
  blockedBy            Block[]               @relation("Blocked")
  reportsMade          Report[]              @relation("Reporter")
  reportsReceived      Report[]              @relation("Reported")
  reportsResolved      Report[]              @relation("Resolver")
  auditLogs            AuditLog[]
  membership           Membership?
  referralsSent        Referral[]            @relation("ReferralInviter")
  referralRecord       Referral?             @relation("ReferralReferredUser")
  membershipGrants     MembershipGrant[]     @relation("MembershipGrantRecipient")
  grantedMemberships   MembershipGrant[]     @relation("MembershipGrantAdmin")
  analyticsPageViews   AnalyticsPageView[]
  analyticsEvents      AnalyticsEvent[]
  forumThreads         ForumThread[]        @relation("ForumThreadAuthor")
  forumPosts           ForumPost[]          @relation("ForumPostAuthor")
  businessListing      BusinessListing?
  jobApplications     JobApplication[]    @relation("JobApplicationApplicant")
  mentorProfile        MentorProfile?
  mentorRequests       MentorRequest[]      @relation("MentorRequestMentee")
  careerResources      CareerResource[]     @relation("CareerResourceAuthor")
  pushSubscriptions    PushSubscription[]

  @@index([email])
  @@index([status])
  @@index([role])
  @@index([createdAt])
  @@index([lastActiveAt])
  passwordHistory PasswordHistory[]

  @@map("users")
}

model Profile {
  id              String    @id @default(uuid())
  userId          String    @unique @map("user_id")
  displayName     String?   @map("display_name")
  bio             String?
  gender          Gender?
  dateOfBirth     DateTime? @map("date_of_birth")
  location        String?
  latitude        Float?
  longitude       Float?
  profileImageUrl String?   @map("profile_image_url")
  interests       String[]  @default([])
  isVisible       Boolean   @default(true) @map("is_visible")
  lastActiveAt    DateTime? @map("last_active_at")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  photos Photo[]

  @@index([location])
  @@index([isVisible])
  @@map("profiles")
}

model Photo {
  id        String   @id @default(uuid())
  profileId String   @map("profile_id")
  url       String
  publicId  String   @map("public_id")
  order     Int      @default(0)
  isPrimary Boolean  @default(false) @map("is_primary")
  width     Int?
  height    Int?
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  profile Profile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@index([profileId])
  @@index([isPrimary])
  @@map("photos")
}

model VeteranDetails {
  id           String          @id @default(uuid())
  userId       String          @unique @map("user_id")
  branch       MilitaryBranch?
  rank         String?
  regiment     String?         // regiment slug e.g. "1-para", "22-sas"
  mos          String?
  dutyStations String[]        @default([]) @map("duty_stations")
  deployments  String[]        @default([])
  createdAt    DateTime        @default(now()) @map("created_at")
  updatedAt    DateTime        @updatedAt @map("updated_at")

  user           User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  servicePeriods ServicePeriod[]

  @@index([regiment])
  @@map("veteran_details")
}

model ServicePeriod {
  id               String         @id @default(uuid())
  veteranDetailsId String         @map("veteran_details_id")
  branch           MilitaryBranch
  startDate        DateTime       @map("start_date")
  endDate          DateTime?      @map("end_date")
  unit             String?
  dutyStation      String?        @map("duty_station")
  createdAt        DateTime       @default(now()) @map("created_at")

  veteranDetails VeteranDetails @relation(fields: [veteranDetailsId], references: [id], onDelete: Cascade)

  @@index([branch])
  @@index([startDate, endDate])
  @@map("service_periods")
}

model VerificationRequest {
  id                String             @id @default(uuid())
  userId            String             @map("user_id")
  status            VerificationStatus @default(PENDING)
  evidenceUrls      String[]           @default([]) @map("evidence_urls")
  evidenceDeletedAt DateTime?          @map("evidence_deleted_at")
  notes             String?
  rejectionReason   String?            @map("rejection_reason")
  reviewerId        String?            @map("reviewer_id")
  reviewedAt        DateTime?          @map("reviewed_at")
  expiresAt         DateTime?          @map("expires_at")
  createdAt         DateTime           @default(now()) @map("created_at")
  updatedAt         DateTime           @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([status])
  @@index([createdAt])
  @@map("verification_requests")
}

model Connection {
  id             String           @id @default(uuid())
  user1Id        String           @map("user1_id")
  user2Id        String           @map("user2_id")
  connectionType ConnectionType   @map("connection_type")
  status         ConnectionStatus @default(PENDING)
  overlapScore   Float?           @map("overlap_score")
  lastMessageAt  DateTime?        @map("last_message_at")
  createdAt      DateTime         @default(now()) @map("created_at")
  updatedAt      DateTime         @updatedAt @map("updated_at")

  user1    User      @relation("ConnectionUser1", fields: [user1Id], references: [id], onDelete: Cascade)
  user2    User      @relation("ConnectionUser2", fields: [user2Id], references: [id], onDelete: Cascade)
  messages Message[]

  @@unique([user1Id, user2Id, connectionType])
  @@index([status])
  @@index([connectionType])
  @@index([lastMessageAt])
  @@map("connections")
}

model Message {
  id               String    @id @default(uuid())
  connectionId     String    @map("connection_id")
  senderId         String    @map("sender_id")
  receiverId       String    @map("receiver_id")
  encryptedContent String    @map("encrypted_content")
  iv               String
  authTag          String    @map("auth_tag")
  readAt           DateTime? @map("read_at")
  editedAt         DateTime? @map("edited_at")
  createdAt        DateTime  @default(now()) @map("created_at")
  deletedAt        DateTime? @map("deleted_at")

  connection Connection @relation(fields: [connectionId], references: [id], onDelete: Cascade)
  sender     User       @relation("MessageSender", fields: [senderId], references: [id], onDelete: Cascade)
  receiver   User       @relation("MessageReceiver", fields: [receiverId], references: [id], onDelete: Cascade)

  @@index([connectionId, createdAt])
  @@index([senderId])
  @@index([receiverId])
  @@map("messages")
}

model Block {
  id        String    @id @default(uuid())
  blockerId String    @map("blocker_id")
  blockedId String    @map("blocked_id")
  reason    String?
  createdAt DateTime  @default(now()) @map("created_at")
  deletedAt DateTime? @map("deleted_at")

  blocker User @relation("Blocker", fields: [blockerId], references: [id], onDelete: Cascade)
  blocked User @relation("Blocked", fields: [blockedId], references: [id], onDelete: Cascade)

  @@unique([blockerId, blockedId])
  @@map("blocks")
}

model Report {
  id             String       @id @default(uuid())
  reporterId     String       @map("reporter_id")
  reportedUserId String       @map("reported_user_id")
  reason         ReportReason
  description    String?
  evidenceUrls   String[]     @default([]) @map("evidence_urls")
  status         ReportStatus @default(PENDING)
  resolution     String?
  resolverId     String?      @map("resolver_id")
  resolvedAt     DateTime?    @map("resolved_at")
  createdAt      DateTime     @default(now()) @map("created_at")
  updatedAt      DateTime     @updatedAt @map("updated_at")

  reporter     User  @relation("Reporter", fields: [reporterId], references: [id], onDelete: Cascade)
  reportedUser User  @relation("Reported", fields: [reportedUserId], references: [id], onDelete: Cascade)
  resolver     User? @relation("Resolver", fields: [resolverId], references: [id])

  @@index([status])
  @@index([reportedUserId])
  @@index([createdAt])
  @@map("reports")
}

model AuditLog {
  id         String   @id @default(uuid())
  userId     String?  @map("user_id")
  action     String
  resource   String
  resourceId String?  @map("resource_id")
  metadata   Json?
  ipAddress  String?  @map("ip_address")
  userAgent  String?  @map("user_agent")
  createdAt  DateTime @default(now()) @map("created_at")

  user User? @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([action])
  @@index([resource])
  @@index([createdAt])
  @@map("audit_logs")
}

model Membership {
  id                   String           @id @default(uuid())
  userId               String           @unique @map("user_id")
  tier                 MembershipTier   @default(FREE)
  status               MembershipStatus @default(ACTIVE)
  stripeCustomerId     String?          @unique @map("stripe_customer_id")
  stripeSubscriptionId String?          @unique @map("stripe_subscription_id")
  stripePriceId        String?          @map("stripe_price_id")
  currentPeriodStart   DateTime?        @map("current_period_start")
  currentPeriodEnd     DateTime?        @map("current_period_end")
  cancelAtPeriodEnd    Boolean          @default(false) @map("cancel_at_period_end")
  createdAt            DateTime         @default(now()) @map("created_at")
  updatedAt            DateTime         @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([tier])
  @@index([status])
  @@index([stripeCustomerId])
  @@map("memberships")
}

model Referral {
  id             String    @id @default(uuid())
  inviterId      String    @map("inviter_id")
  referredUserId String    @unique @map("referred_user_id")
  referralCode   String    @map("referral_code")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")
  qualifiedAt    DateTime? @map("qualified_at")

  inviter      User             @relation("ReferralInviter", fields: [inviterId], references: [id], onDelete: Cascade)
  referredUser User             @relation("ReferralReferredUser", fields: [referredUserId], references: [id], onDelete: Cascade)

  @@index([inviterId, qualifiedAt])
  @@map("referrals")
}

model MembershipGrant {
  id                String                @id @default(uuid())
  userId            String                @map("user_id")
  tier              MembershipTier
  source            MembershipGrantSource
  adminId           String?               @map("admin_id")
  referralMilestone Int?                  @map("referral_milestone")
  label             String?
  startsAt          DateTime              @map("starts_at")
  endsAt            DateTime              @map("ends_at")
  createdAt         DateTime              @default(now()) @map("created_at")
  updatedAt         DateTime              @updatedAt @map("updated_at")

  user  User   @relation("MembershipGrantRecipient", fields: [userId], references: [id], onDelete: Cascade)
  admin User?  @relation("MembershipGrantAdmin", fields: [adminId], references: [id])

  @@index([userId, startsAt, endsAt])
  @@index([source, referralMilestone])
  @@map("membership_grants")
}

model AnalyticsPageView {
  id                       String    @id @default(uuid())
  sessionId                String    @map("session_id")
  userId                   String?   @map("user_id")
  path                     String
  referrer                 String?
  loadTimeMs               Int?      @map("load_time_ms")
  domContentLoadedMs       Int?      @map("dom_content_loaded_ms")
  firstPaintMs             Int?      @map("first_paint_ms")
  firstContentfulPaintMs   Int?      @map("first_contentful_paint_ms")
  largestContentfulPaintMs Int?      @map("largest_contentful_paint_ms")
  viewportWidth            Int?      @map("viewport_width")
  viewportHeight           Int?      @map("viewport_height")
  deviceType               String?   @map("device_type")
  createdAt                DateTime  @default(now()) @map("created_at")

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([createdAt])
  @@index([path, createdAt])
  @@index([sessionId, createdAt])
  @@index([userId])
  @@map("analytics_page_views")
}

model AnalyticsEvent {
  id        String   @id @default(uuid())
  sessionId String   @map("session_id")
  userId    String?  @map("user_id")
  event     String
  path      String?
  metadata  Json?
  createdAt DateTime @default(now()) @map("created_at")

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([event, createdAt])
  @@index([sessionId, createdAt])
  @@index([userId])
  @@map("analytics_events")
}

// ============ BIA MODELS ============

model ForumCategory {
  id          String   @id @default(uuid())
  slug        String   @unique
  name        String
  description String?
  icon        String   @default("MessageSquare")
  tier        String   @default("BIA") // "BIA" | "BIA_PLUS" | "REGIMENT"
  regiment    String?  // regiment slug, set when tier = "REGIMENT"
  sortOrder   Int      @default(0) @map("sort_order")
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  threads ForumThread[]

  @@index([slug])
  @@index([tier])
  @@index([regiment])
  @@map("forum_categories")
}

model ForumThread {
  id          String    @id @default(uuid())
  categoryId  String    @map("category_id")
  authorId    String    @map("author_id")
  title       String
  isPinned    Boolean   @default(false) @map("is_pinned")
  isLocked    Boolean   @default(false) @map("is_locked")
  viewCount   Int       @default(0) @map("view_count")
  postCount   Int       @default(0) @map("post_count")
  lastPostAt  DateTime  @default(now()) @map("last_post_at")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  deletedAt   DateTime? @map("deleted_at")

  category ForumCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  author   User          @relation("ForumThreadAuthor", fields: [authorId], references: [id], onDelete: Cascade)
  posts    ForumPost[]

  @@index([categoryId, lastPostAt])
  @@index([authorId])
  @@map("forum_threads")
}

model ForumPost {
  id        String    @id @default(uuid())
  threadId  String    @map("thread_id")
  authorId  String    @map("author_id")
  content   String
  editedAt  DateTime? @map("edited_at")
  createdAt DateTime  @default(now()) @map("created_at")
  deletedAt DateTime? @map("deleted_at")

  thread ForumThread @relation(fields: [threadId], references: [id], onDelete: Cascade)
  author User        @relation("ForumPostAuthor", fields: [authorId], references: [id], onDelete: Cascade)

  @@index([threadId, createdAt])
  @@index([authorId])
  @@map("forum_posts")
}

model BusinessListing {
  id          String    @id @default(uuid())
  userId      String    @unique @map("user_id")
  name        String
  description String
  category    String
  website     String?
  phone       String?
  location    String?
  logoUrl     String?   @map("logo_url")
  isApproved  Boolean   @default(false) @map("is_approved")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  jobs JobListing[]

  @@index([userId])
  @@index([category])
  @@index([isApproved])
  @@map("business_listings")
}

model JobListing {
  id                String    @id @default(uuid())
  businessListingId String    @map("business_listing_id")
  title             String
  employmentType    String    @map("employment_type")
  location          String?
  summary           String?
  description       String
  isActive          Boolean   @default(true) @map("is_active")
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")

  businessListing BusinessListing @relation(fields: [businessListingId], references: [id], onDelete: Cascade)
  applications    JobApplication[]

  @@index([businessListingId, isActive])
  @@index([createdAt])
  @@map("job_listings")
}

model JobApplication {
  id             String    @id @default(uuid())
  jobListingId   String    @map("job_listing_id")
  applicantId    String    @map("applicant_id")
  name           String
  email          String
  message        String?
  cvPublicId     String    @map("cv_public_id")
  cvFileName     String    @map("cv_file_name")
  cvMimeType     String    @map("cv_mime_type")
  cvBytes        Int       @map("cv_bytes")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  jobListing JobListing @relation(fields: [jobListingId], references: [id], onDelete: Cascade)
  applicant  User       @relation("JobApplicationApplicant", fields: [applicantId], references: [id], onDelete: Cascade)

  @@index([jobListingId, createdAt])
  @@index([applicantId])
  @@map("job_applications")
}

model MentorProfile {
  id           String    @id @default(uuid())
  userId       String    @unique @map("user_id")
  headline     String
  expertise    String[]  @default([])
  availability String?
  isActive     Boolean   @default(true) @map("is_active")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  user     User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  requests MentorRequest[]

  @@index([isActive])
  @@map("mentor_profiles")
}

model MentorRequest {
  id        String   @id @default(uuid())
  mentorId  String   @map("mentor_id")
  menteeId  String   @map("mentee_id")
  message   String?
  status    String   @default("PENDING") // PENDING | ACCEPTED | DECLINED
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  mentor  MentorProfile @relation(fields: [mentorId], references: [id], onDelete: Cascade)
  mentee  User          @relation("MentorRequestMentee", fields: [menteeId], references: [id], onDelete: Cascade)

  @@index([mentorId])
  @@index([menteeId])
  @@index([status])
  @@map("mentor_requests")
}

model CareerResource {
  id          String    @id @default(uuid())
  authorId    String    @map("author_id")
  title       String
  content     String
  category    String
  tags        String[]  @default([])
  isPublished Boolean   @default(false) @map("is_published")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  author User @relation("CareerResourceAuthor", fields: [authorId], references: [id], onDelete: Cascade)

  @@index([category])
  @@index([isPublished])
  @@map("career_resources")
}

model PushSubscription {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  endpoint  String   @unique
  p256dh    String
  auth      String
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("push_subscriptions")
}

model PasswordHistory {
  id           String   @id @default(uuid())
  userId       String   @map("user_id")
  passwordHash String   @map("password_hash")
  createdAt    DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@map("password_history")
}
