# ── Local development .env ────────────────────────────────────────────────────
# Copy this to .env and fill in real values.
# Never commit a .env file — it is gitignored.

# ── Database ──────────────────────────────────────────────────────────────────
# connection_limit: max connections Prisma will hold open.
#   Keep this below (postgres max_connections - 5) divided by the number of
#   API processes you run.  Docker postgres defaults to max_connections=100.
#   For local dev with one process, 10 is safe and leaves 90 for admin tools.
#
# pool_timeout: seconds to wait for a free connection before throwing P2024.
#   20 s is generous for local dev.  In production use 10 s.
#
# connect_timeout: seconds for the initial TCP handshake.
#   10 s handles slow container start-up during docker compose up.
DATABASE_URL=postgresql://veteranfinder:veteranfinder@localhost:5432/veteranfinder?connection_limit=10&pool_timeout=20&connect_timeout=10

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── JWT ───────────────────────────────────────────────────────────────────────
JWT_SECRET=dev-jwt-secret-min-32-chars-longggggg
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=dev-refresh-secret-32-chars-longg
JWT_REFRESH_EXPIRES_IN=7d

# ── Encryption ────────────────────────────────────────────────────────────────
# AES-256-GCM message key — must be exactly 32 characters for local dev
ENCRYPTION_KEY=dev-encryption-key-32-chars-longg

# ── Security secrets (CRITICAL — generate real values before any real data) ──
# openssl rand -hex 32
PASSWORD_PEPPER=dev-pepper-replace-before-real-users-32-chars
COOKIE_SECRET=dev-cookie-secret-replace-before-real-users

# ── Server ────────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development
FRONTEND_URL=http://localhost:3001
ADMIN_URL=http://localhost:3002
CORS_ORIGIN=http://localhost:3001

# ── Email (Mailpit local dev — no real emails sent) ──────────────────────────
SMTP_HOST=localhost
SMTP_PORT=1025
FROM_EMAIL=noreply@veteranfinder.local

# ── Cloudinary (optional for dev — uploads will fail gracefully without it) ──
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ── Stripe (optional for dev — subscription routes will return 503 without it) -
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_BIA_BASIC_MONTHLY=
STRIPE_PRICE_BIA_BASIC_ANNUAL=
STRIPE_PRICE_BIA_PLUS_MONTHLY=
STRIPE_PRICE_BIA_PLUS_ANNUAL=

# ── Web Push / VAPID (optional for dev — push notifications won't send) ──────
# Generate: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:dev@veteranfinder.local
