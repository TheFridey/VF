# ═══════════════════════════════════════════════════════════════════════════════
# VeteranFinder — API environment configuration
# Copy to .env.local for local development. NEVER commit .env.local.
# All production secrets should be injected via a secrets manager.
# ═══════════════════════════════════════════════════════════════════════════════

# ── Database ───────────────────────────────────────────────────────────────────
# connection_limit: max connections Prisma opens (≤ max_connections / num_replicas)
# pool_timeout:    seconds to wait for a free connection before P2024
# connect_timeout: seconds for initial TCP connection
DATABASE_URL=postgresql://veteranfinder:veteranfinder@localhost:5432/veteranfinder?connection_limit=10&pool_timeout=20&connect_timeout=10

# ── Redis ──────────────────────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
# Set for production:
# REDIS_PASSWORD=generate-with-openssl-rand-hex-32

# ── JWT Authentication ─────────────────────────────────────────────────────────
# Generate both with: openssl rand -hex 32
JWT_SECRET=development-jwt-secret-min-32-chars-long
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=development-refresh-secret-32-chars
JWT_REFRESH_EXPIRES_IN=7d

# ── Cookie ─────────────────────────────────────────────────────────────────────
# Used by cookie-parser to sign session cookies.
# Generate: openssl rand -hex 32
COOKIE_SECRET=generate-with-openssl-rand-hex-32

# ── Message encryption (AES-256-GCM) ──────────────────────────────────────────
# MUST be exactly 32 characters.
# Generate: openssl rand -hex 16
ENCRYPTION_KEY=0123456789abcdef0123456789abcdef
# Optional: comma-separated previous keys to keep older messages readable after rotation
ENCRYPTION_KEY_FALLBACKS=

# ── Password pepper (HMAC-SHA256) ─────────────────────────────────────────────
# Applied before Argon2id hashing. A database breach alone yields nothing
# without this key. Min 32 chars. Rotating this invalidates all passwords.
# Generate: openssl rand -hex 32
PASSWORD_PEPPER=generate-with-openssl-rand-hex-32-minimum-32-chars

# ── Server ─────────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ── CORS / Frontend URLs ───────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:3001
ADMIN_URL=http://localhost:3002
# Production:
# FRONTEND_URL=https://veteranfinder.co.uk
# ADMIN_URL=https://admin.veteranfinder.co.uk

# ── Cloudinary (image & video uploads) ────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# ── Stripe (BIA membership payments) ──────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_your-secret-key
STRIPE_PUBLISHABLE_KEY=pk_test_your-publishable-key
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-secret

# BIA membership Price IDs — create in Stripe Dashboard, paste IDs here
STRIPE_PRICE_BIA_BASIC_MONTHLY=price_bia_basic_monthly_id
STRIPE_PRICE_BIA_BASIC_ANNUAL=price_bia_basic_annual_id
STRIPE_PRICE_BIA_PLUS_MONTHLY=price_bia_plus_monthly_id
STRIPE_PRICE_BIA_PLUS_ANNUAL=price_bia_plus_annual_id

# Business listing price — £15/month (create separately in Stripe)
STRIPE_PRICE_DIRECTORY_MONTHLY=price_directory_monthly_id

# ── Email (Resend) ─────────────────────────────────────────────────────────────
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
FROM_EMAIL=VeteranFinder <noreply@veteranfinder.co.uk>
APP_URL=https://veteranfinder.co.uk
PARTNERSHIPS_EMAIL_TO=partnerships@veteranfinder.co.uk

# Local development — uses Mailpit (SMTP on :1025, UI on :8025)
SMTP_HOST=localhost
SMTP_PORT=1025

# ── TURN / STUN (coturn — video calls) ────────────────────────────────────────
TURN_HOST=turn.veteranfinder.co.uk
# Generate: openssl rand -hex 32
TURN_SECRET=generate-with-openssl-rand-hex-32

# ── Push notifications (VAPID) ─────────────────────────────────────────────────
# Generate: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=your-vapid-public-key
VAPID_PRIVATE_KEY=your-vapid-private-key
VAPID_SUBJECT=mailto:admin@veteranfinder.co.uk

# ── Logging ────────────────────────────────────────────────────────────────────
# LOG_LEVEL=info   (debug | info | warn | error)
# Defaults to 'info' in production, 'debug' in development.

# ── Feature flags ──────────────────────────────────────────────────────────────
# These can also be set via environment for gradual rollout
# FEATURE_VIDEO_CALLS=true
# FEATURE_PUSH_NOTIFICATIONS=true
