# Database
DATABASE_URL=postgresql://veteranfinder:veteranfinder@localhost:5432/veteranfinder

# Redis
REDIS_URL=redis://localhost:6379

# JWT Authentication
JWT_SECRET=development-jwt-secret-min-32-chars-long
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=development-refresh-secret-32-chars
JWT_REFRESH_EXPIRES_IN=7d

# Encryption
ENCRYPTION_KEY=development-encryption-key-32ch

# Server
PORT=3000
NODE_ENV=development

# Frontend
FRONTEND_URL=http://localhost:3001
CORS_ORIGIN=http://localhost:3001

# AWS S3 (optional - file uploads disabled if not configured)
# AWS_REGION=us-east-1
# AWS_ACCESS_KEY_ID=minioadmin
# AWS_SECRET_ACCESS_KEY=minioadmin
# AWS_S3_BUCKET=veteranfinder-uploads
# AWS_S3_ENDPOINT=http://localhost:9000

# Cloudinary (for image uploads)
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# Stripe (for payments)
STRIPE_SECRET_KEY=sk_test_your-secret-key
STRIPE_PUBLISHABLE_KEY=pk_test_your-publishable-key
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-secret
STRIPE_PRICE_MONTHLY=price_monthly_id
STRIPE_PRICE_ANNUAL=price_annual_id

# Email (Mailpit)
SMTP_HOST=localhost
SMTP_PORT=1025
FROM_EMAIL=noreply@veteranfinder.local
