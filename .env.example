# Database
DB_USER=veteranfinder
DB_PASSWORD=change-me
DB_NAME=veteranfinder

# Redis
REDIS_PASSWORD=change-me

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=your-super-secret-refresh-key-change-in-production
JWT_REFRESH_EXPIRES_IN=7d

# Cookie
COOKIE_SECRET=your-cookie-secret-change-in-production

# Encryption (AES-256 for messages)
ENCRYPTION_KEY=your-encryption-key-exactly-32ch

# AWS S3
AWS_REGION=eu-west-2
AWS_ACCESS_KEY_ID=your-access-key
AWS_SECRET_ACCESS_KEY=your-secret-key
AWS_S3_BUCKET=veteranfinder-uploads

# App
NODE_ENV=production
PORT=3000
FRONTEND_URL=https://veteranfinder.co.uk
ADMIN_URL=https://admin.veteranfinder.co.uk

# ─── Resend Email ─────────────────────────────────────────────────────────────
RESEND_API_KEY=re_xxxxxxxx
FROM_EMAIL=VeteranFinder <noreply@veteranfinder.co.uk>
CONTACT_EMAIL=hello@veteranfinder.co.uk
SUPPORT_EMAIL=support@veteranfinder.co.uk
PRIVACY_EMAIL=privacy@veteranfinder.co.uk
LEGAL_EMAIL=legal@veteranfinder.co.uk
APP_URL=https://veteranfinder.co.uk
PARTNERSHIPS_EMAIL_TO=partnerships@veteranfinder.co.uk

# Stripe
STRIPE_SECRET_KEY=sk_live_xxxxxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxx
STRIPE_PRICE_BIA_BASIC_MONTHLY=price_xxxxxxxx
STRIPE_PRICE_BIA_BASIC_ANNUAL=price_xxxxxxxx
STRIPE_PRICE_BIA_PLUS_MONTHLY=price_xxxxxxxx
STRIPE_PRICE_BIA_PLUS_ANNUAL=price_xxxxxxxx

# ─── TURN server (coturn) ─────────────────────────────────────────────────────
TURN_HOST=turn.veteranfinder.co.uk
TURN_SECRET=generate-with-openssl-rand-hex-32
